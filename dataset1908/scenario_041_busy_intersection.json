    "criteria": {
      "lane_type": "Driving",
      "is_intersection": true,
      "junction_proximity": {"min": 10, "max": 30}
    }
  },
  "ego_start_speed": 5,
  "actors": [
    {
      "id": "cross_vehicle_1",
      "type": "vehicle",
      "model": "vehicle.toyota.prius",

{
  "scenario_name": "slow_vehicle_cut_in",
  "description": "Slow vehicle cuts in front",
  "weather": "cloudy",
  "ego_vehicle_model": "vehicle.ford.mustang",
  "ego_spawn": {
    "criteria": {
      "lane_type": "Driving",
      "is_intersection": false,
      "road_context": "urban"
    }
  },
  "ego_start_speed": 15,
  "actors": [
    {
      "id": "slow_cutter",
      "type": "vehicle",
      "model": "vehicle.volkswagen.t2",
      "spawn": {
        "criteria": {
          "lane_type": "Driving",
          "distance_to_ego": {"min": 25, "max": 35},
          "relative_position": "ahead",
          "road_relationship": "same_road",
          "lane_relationship": "adjacent_lane"
        }
      }
    }
  ],
  "actions": [
    {
      "actor_id": "slow_cutter",
      "action_type": "speed",
      "trigger_type": "time",
      "trigger_value": 0,
      "speed_value": 8,
      "dynamics_dimension": "time",
      "dynamics_shape": "step",
      "dynamics_value": 0.5
    },
    {
      "actor_id": "slow_cutter",
      "action_type": "lane_change",
      "trigger_type": "distance_to_ego",
      "trigger_value": 20,
      "trigger_comparison": "<",
      "target_lane": "same_as_ego",
      "dynamics_dimension": "time",
      "dynamics_shape": "linear",
      "dynamics_value": 3
    }
  ],
  "success_distance": 80,
  "timeout": 60,
  "collision_allowed": false
}
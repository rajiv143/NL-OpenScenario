          "lane_type": "Driving",
          "distance_to_ego": {"min": 30, "max": 40},
          "relative_position": "ahead",
          "road_relationship": "same_road",
          "lane_relationship": "adjacent_lane"
        }
      }
    }
  ],
  "actions": [
    {
      "actor_id": "suburban_merger",
      "action_type": "speed",
      "trigger_type": "time",
      "trigger_value": 0,
      "speed_value": 10,
      "dynamics_dimension": "time",
      "dynamics_shape": "step",
      "dynamics_value": 0.5
    },
    {
      "actor_id": "suburban_merger",
      "action_type": "speed",
      "trigger_type": "time",
      "trigger_value": 2,
      "speed_value": 8,
      "dynamics_dimension": "time",
      "dynamics_shape": "linear",
      "dynamics_value": 1
    },
    {
      "actor_id": "suburban_merger",
      "action_type": "lane_change",
      "trigger_type": "after_previous",
      "trigger_value": 1,
      "target_lane": "same_as_ego",
      "dynamics_dimension": "time",
      "dynamics_shape": "cubic",
      "dynamics_value": 3

{
  "scenario_name": "suburban_merge_scenario",
  "description": "Merging in suburban traffic",
  "weather": "wet",
  "ego_vehicle_model": "vehicle.seat.leon",
  "ego_spawn": {
    "criteria": {
      "lane_type": "Driving",
      "is_intersection": false,
      "road_context": "suburban"
    }
  },
  "ego_start_speed": 10,
  "actors": [
    {
      "id": "suburban_merger",
      "type": "vehicle",
      "model": "vehicle.citroen.c3",

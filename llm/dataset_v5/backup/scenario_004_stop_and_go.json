{
  "scenario_name": "stop_and_go_traffic",
  "description": "Lead vehicle stops then resumes",
  "weather": "clear",
  "ego_vehicle_model": "vehicle.audi.tt",
  "ego_spawn": {
    "criteria": {
      "lane_type": "Driving",
      "is_intersection": false,
      "road_context": "urban"
    }
  },
  "ego_start_speed": 8,
  "actors": [
    {
      "id": "traffic_vehicle",
      "type": "vehicle",
      "model": "vehicle.chevrolet.impala",
      "spawn": {
        "criteria": {
          "lane_type": "Driving",
          "distance_to_ego": {"min": 20, "max": 30},
          "relative_position": "ahead",
          "road_relationship": "same_road",
          "lane_relationship": "same_lane"
        }
      }
    }
  ],
  "actions": [
    {
      "actor_id": "traffic_vehicle",
      "action_type": "speed",
      "trigger_type": "time",
      "trigger_value": 0,
      "speed_value": 8,
      "dynamics_dimension": "time",
      "dynamics_shape": "step",
      "dynamics_value": 0.5
    },
    {
      "actor_id": "traffic_vehicle",
      "action_type": "stop",
      "trigger_type": "time",
      "trigger_value": 3,
      "dynamics_dimension": "time",
      "dynamics_shape": "linear",
      "dynamics_value": 2
    },
    {
      "actor_id": "traffic_vehicle",
      "action_type": "wait",
      "trigger_type": "after_previous",
      "trigger_value": 0,
      "wait_duration": 2
    },
    {
      "actor_id": "traffic_vehicle",
      "action_type": "speed",
      "trigger_type": "after_previous",
      "trigger_value": 0,
      "speed_value": 10,
      "dynamics_dimension": "time",
      "dynamics_shape": "linear",
      "dynamics_value": 3
    }
  ],
  "success_distance": 100,
  "timeout": 60,
  "collision_allowed": false
}
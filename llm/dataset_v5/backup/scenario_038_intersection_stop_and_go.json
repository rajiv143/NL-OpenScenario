{
  "scenario_name": "intersection_stop_and_proceed",
  "description": "Vehicle stops then proceeds through intersection",
  "weather": "wet",
  "ego_vehicle_model": "vehicle.chevrolet.impala",
  "ego_spawn": {
    "criteria": {
      "lane_type": "Driving",
      "is_intersection": true,
      "junction_proximity": {"min": 5, "max": 25}
    }
  },
  "ego_start_speed": 5,
  "actors": [
    {
      "id": "intersection_stopper",
      "type": "vehicle",
      "model": "vehicle.nissan.patrol",
      "spawn": {
        "criteria": {
          "lane_type": "Driving",
          "is_intersection": true,
          "distance_to_ego": {"min": 30, "max": 40},
          "relative_position": "perpendicular",
          "road_relationship": "different_road"
        }
      }
    }
  ],
  "actions": [
    {
      "actor_id": "intersection_stopper",
      "action_type": "speed",
      "trigger_type": "time",
      "trigger_value": 0,
      "speed_value": 8,
      "dynamics_dimension": "time",
      "dynamics_shape": "step",
      "dynamics_value": 0.5
    },
    {
      "actor_id": "intersection_stopper",
      "action_type": "stop",
      "trigger_type": "time",
      "trigger_value": 2,
      "dynamics_dimension": "time",
      "dynamics_shape": "linear",
      "dynamics_value": 2
    },
    {
      "actor_id": "intersection_stopper",
      "action_type": "wait",
      "trigger_type": "after_previous",
      "trigger_value": 0,
      "wait_duration": 3
    },
    {
      "actor_id": "intersection_stopper",
      "action_type": "speed",
      "trigger_type": "after_previous",
      "trigger_value": 0,
      "speed_value": 10,
      "dynamics_dimension": "time",
      "dynamics_shape": "linear",
      "dynamics_value": 2
    }
  ],
  "success_distance": 80,
  "timeout": 60,
  "collision_allowed": false
}
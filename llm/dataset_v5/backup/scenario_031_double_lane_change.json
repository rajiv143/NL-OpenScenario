{
  "scenario_name": "double_lane_change",
  "description": "Vehicle changes lanes twice",
  "weather": "clear",
  "ego_vehicle_model": "vehicle.chevrolet.impala",
  "ego_spawn": {
    "criteria": {
      "lane_type": "Driving",
      "lane_id": {"min": 2, "max": 3},
      "is_intersection": false,
      "road_context": "highway"
    }
  },
  "ego_start_speed": 22,
  "actors": [
    {
      "id": "lane_hopper",
      "type": "vehicle",
      "model": "vehicle.ford.crown",
      "spawn": {
        "criteria": {
          "lane_type": "Driving",
          "distance_to_ego": {"min": 40, "max": 50},
          "relative_position": "ahead",
          "road_relationship": "same_road",
          "lane_relationship": "adjacent_lane"
        }
      }
    }
  ],
  "actions": [
    {
      "actor_id": "lane_hopper",
      "action_type": "speed",
      "trigger_type": "time",
      "trigger_value": 0,
      "speed_value": 20,
      "dynamics_dimension": "time",
      "dynamics_shape": "step",
      "dynamics_value": 0.5
    },
    {
      "actor_id": "lane_hopper",
      "action_type": "lane_change",
      "trigger_type": "time",
      "trigger_value": 2,
      "target_lane": "same_as_ego",
      "dynamics_dimension": "time",
      "dynamics_shape": "sinusoidal",
      "dynamics_value": 2
    },
    {
      "actor_id": "lane_hopper",
      "action_type": "lane_change",
      "trigger_type": "after_previous",
      "trigger_value": 3,
      "target_lane": -1,
      "dynamics_dimension": "time",
      "dynamics_shape": "sinusoidal",
      "dynamics_value": 2
    }
  ],
  "success_distance": 120,
  "timeout": 70,
  "collision_allowed": false
}
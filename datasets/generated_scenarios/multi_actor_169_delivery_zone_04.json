{
  "scenario_name": "delivery_zone_04",
  "description": "Delivery truck with pedestrian activity",
  "weather": "clear_sunset",
  "ego_vehicle_model": "vehicle.audi.a2",
  "ego_spawn": {
    "criteria": {
      "lane_type": "Driving",
      "is_intersection": false,
      "lane_id": {
        "min": 1,
        "max": 4
      }
    }
  },
  "ego_start_speed": 0,
  "actors": [
    {
      "id": "delivery",
      "type": "vehicle",
      "model": "vehicle.mercedes.sprinter",
      "spawn": {
        "criteria": {
          "lane_type": "Sidewalk",
          "distance_to_ego": {
            "min": 65,
            "max": 95
          },
          "relative_position": "ahead"
        }
      }
    },
    {
      "id": "delivery_worker",
      "type": "pedestrian",
      "model": "walker.pedestrian.0030",
      "spawn": {
        "criteria": {
          "lane_type": "Sidewalk",
          "distance_to_ego": {
            "min": 55,
            "max": 85
          },
          "lateral_offset": 3.0
        }
      }
    },
    {
      "id": "customer",
      "type": "pedestrian",
      "model": "walker.pedestrian.0020",
      "spawn": {
        "criteria": {
          "lane_type": "Sidewalk",
          "distance_to_ego": {
            "min": 70,
            "max": 100
          },
          "lateral_offset": 3.0
        }
      }
    }
  ],
  "actions": [
    {
      "actor_id": "delivery",
      "action_type": "speed",
      "trigger_type": "distance_to_ego",
      "trigger_value": 50,
      "trigger_comparison": "<",
      "speed_value": 6.0,
      "dynamics_dimension": "time",
      "dynamics_value": 2.0
    },
    {
      "actor_id": "delivery",
      "action_type": "stop",
      "trigger_type": "after_previous",
      "dynamics_dimension": "time",
      "dynamics_value": 2.5
    },
    {
      "actor_id": "delivery_worker",
      "action_type": "speed",
      "trigger_type": "distance_to_ego",
      "trigger_value": 40,
      "trigger_comparison": "<",
      "speed_value": 1.2,
      "dynamics_dimension": "time",
      "dynamics_value": 1.5
    },
    {
      "actor_id": "customer",
      "action_type": "wait",
      "trigger_type": "distance_to_ego",
      "trigger_value": 55,
      "trigger_comparison": "<",
      "wait_duration": 2.0
    },
    {
      "actor_id": "customer",
      "action_type": "speed",
      "trigger_type": "after_previous",
      "speed_value": 1.0,
      "dynamics_dimension": "time",
      "dynamics_value": 2.0
    }
  ],
  "success_distance": 70,
  "timeout": 60,
  "collision_allowed": false
}
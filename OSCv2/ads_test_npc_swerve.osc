import basic.osc

scenario top:
    path: Path                 
    path.set_map("Town04")
    path.path_min_driving_lanes(2)

    ego_vehicle: Model3                 # ego car
    npc: Rubicon                        # The other car

    event start
    event end
    do parallel(duration: 12s):
        ego_vehicle.drive(path) with:
            speed(50kph)
            lane(2, at: start)
        
        serial:
            npc_parallel_drive: parallel(duration: 5s):
                npc.drive(path) with:
                    speed(60kph)
                    lane(1, at: start) # left to right: [1..n]
                    position(5m, behind: ego_vehicle, at: start)

            npc_sudden_swerve: parallel(duration: 2s):
                npc.drive(path) with:
                    speed(60kph)
                    lane(same_as: ego_vehicle, at: end)


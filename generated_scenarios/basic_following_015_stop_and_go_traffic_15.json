{
  "scenario_name": "stop_and_go_traffic_15",
  "description": "Lead vehicle alternates between stop and go",
  "weather": "hard_rain",
  "ego_vehicle_model": "vehicle.audi.a2",
  "ego_spawn": {
    "criteria": {
      "lane_type": "Driving",
      "is_intersection": false,
      "lane_id": {
        "min": 1,
        "max": 4
      }
    }
  },
  "ego_start_speed": 0,
  "actors": [
    {
      "id": "lead_vehicle",
      "type": "vehicle",
      "model": "vehicle.carlamotors.european_hgv",
      "spawn": {
        "criteria": {
          "road_relationship": "same_road",
          "lane_relationship": "same_lane",
          "relative_position": "ahead",
          "distance_to_ego": {
            "min": 40,
            "max": 70
          }
        }
      },
      "color": "128,0,255"
    }
  ],
  "actions": [
    {
      "actor_id": "lead_vehicle",
      "action_type": "speed",
      "trigger_type": "distance_to_ego",
      "trigger_value": 25,
      "trigger_comparison": "<",
      "speed_value": 8.0,
      "dynamics_dimension": "time",
      "dynamics_value": 2.0
    },
    {
      "actor_id": "lead_vehicle",
      "action_type": "stop",
      "trigger_type": "after_previous",
      "dynamics_dimension": "time",
      "dynamics_value": 2.0
    },
    {
      "actor_id": "lead_vehicle",
      "action_type": "wait",
      "trigger_type": "after_previous",
      "wait_duration": 4.0
    },
    {
      "actor_id": "lead_vehicle",
      "action_type": "speed",
      "trigger_type": "after_previous",
      "speed_value": 10.0,
      "dynamics_dimension": "time",
      "dynamics_value": 2.0
    }
  ],
  "success_distance": 60,
  "timeout": 120,
  "collision_allowed": false
}